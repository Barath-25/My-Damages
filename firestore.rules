rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: transactions
    // Document ID: auto-generated
    // Fields:
    //   - amount: number (required, > 0)
    //   - type: string (required, 'income' or 'expense')
    //   - category: string (required, max 50 chars)
    //   - otherCategory: string (optional, max 50 chars)
    //   - date: timestamp (required)
    //   - description: string (optional, max 200 chars)
    //   - uid: string (required, matches auth.uid)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidTransaction(data) {
      return data.amount is number && data.amount > 0 &&
             data.type in ['income', 'expense', 'transfer'] &&
             data.paymentMethod in ['upi', 'cash'] &&
             data.category is string && data.category.size() <= 50 &&
             (!('otherCategory' in data) || (data.otherCategory is string && data.otherCategory.size() <= 50)) &&
             data.date is timestamp &&
             (!('description' in data) || (data.description is string && data.description.size() <= 200)) &&
             data.uid == request.auth.uid &&
             data.accountId is string &&
             data.createdAt is timestamp;
    }

    function isValidWishlistItem(data) {
      return data.name is string && data.name.size() > 0 &&
             data.targetAmount is number && data.targetAmount > 0 &&
             data.savedAmount is number && data.savedAmount >= 0 &&
             data.uid == request.auth.uid &&
             data.createdAt is timestamp;
    }

    function isValidBudget(data) {
      return data.month is string && data.month.matches('^\\d{4}-\\d{2}$') &&
             data.amount is number && data.amount >= 0 &&
             data.uid == request.auth.uid;
    }

    function isValidProfile(data) {
      return data.displayName is string && data.displayName.size() > 0 &&
             (!('photoURL' in data) || data.photoURL is string) &&
             (!('securityPin' in data) || (data.securityPin is string && data.securityPin.matches('^[0-9]{4}$'))) &&
             (!('useBiometrics' in data) || data.useBiometrics is bool) &&
             data.setupComplete is bool;
    }

    function isValidAccount(data) {
      return data.name is string && data.name.size() > 0 &&
             data.uid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidTransaction(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidTransaction(request.resource.data) &&
                      request.resource.data.uid == resource.data.uid &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /accounts/{accountId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidAccount(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidAccount(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId && isValidProfile(request.resource.data);
    }

    match /wishlist/{itemId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidWishlistItem(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidWishlistItem(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /budgets/{budgetId} {
      allow read: if isAuthenticated() && resource.data.uid == request.auth.uid;
      allow create: if isAuthenticated() && isValidBudget(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidBudget(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }
    
    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
