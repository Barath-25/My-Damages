{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user profile information and security settings.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "The user's profile photo URL." },
        "securityPin": { "type": "string", "description": "A 4-digit security PIN for app access." },
        "upiId": { "type": "string", "description": "The user's default UPI ID." },
        "setupComplete": { "type": "boolean", "description": "Whether the user has completed the initial setup." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created." }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Account": {
      "title": "Bank Account",
      "description": "Represents a bank or cash account.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The owner's user ID." },
        "name": { "type": "string", "description": "The name of the account (e.g., 'SBI Savings')." },
        "bankName": { "type": "string", "description": "The name of the bank." },
        "upiId": { "type": "string", "description": "The UPI ID associated with this account." },
        "isMain": { "type": "boolean", "description": "Whether this is the primary account." },
        "balance": { "type": "number", "description": "Current balance in the account." },
        "type": { "type": "string", "enum": ["bank", "cash"], "description": "The type of account." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the account was created." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the account was last updated." }
      },
      "required": ["uid", "name", "balance", "type"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A record of income, expense, or transfer.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The owner's user ID." },
        "accountId": { "type": "string", "description": "The ID of the account this transaction belongs to." },
        "amount": { "type": "number", "description": "The transaction amount." },
        "type": { "type": "string", "enum": ["income", "expense", "transfer"], "description": "The type of transaction." },
        "category": { "type": "string", "description": "The category of the transaction (e.g., 'Food', 'Salary')." },
        "date": { "type": "string", "format": "date-time", "description": "The date of the transaction." },
        "note": { "type": "string", "description": "An optional note for the transaction." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the transaction was recorded." }
      },
      "required": ["uid", "accountId", "amount", "type", "date"]
    },
    "WishlistItem": {
      "title": "Wishlist Item",
      "description": "An item the user wants to save for.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The owner's user ID." },
        "name": { "type": "string", "description": "The name of the item." },
        "price": { "type": "number", "description": "The price of the item." },
        "priority": { "type": "string", "enum": ["low", "medium", "high"], "description": "The priority of the item." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the item was added." }
      },
      "required": ["uid", "name", "price"]
    },
    "Debt": {
      "title": "Debt",
      "description": "Money owed to or by the user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The owner's user ID." },
        "personName": { "type": "string", "description": "The name of the person involved." },
        "amount": { "type": "number", "description": "The amount owed." },
        "type": { "type": "string", "enum": ["owe", "owed"], "description": "Whether the user owes or is owed." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the debt was recorded." }
      },
      "required": ["uid", "personName", "amount", "type"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "UserProfile", "description": "User profiles." },
    "/accounts/{accountId}": { "schema": "Account", "description": "Bank and cash accounts." },
    "/transactions/{transactionId}": { "schema": "Transaction", "description": "Financial transactions." },
    "/wishlist/{itemId}": { "schema": "WishlistItem", "description": "User wishlist items." },
    "/debts/{debtId}": { "schema": "Debt", "description": "Debts and money owed." }
  }
}
